<Application x:Class="WPF_pp_practice.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WPF_pp_practice"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style TargetType="Page">
            <Setter Property="Background" Value="#FFFFFF"></Setter>
            <Setter Property="FontFamily" Value="Courier New"></Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#A163F5"></Setter>
        </Style>
        <SolidColorBrush x:Key="MoreColor">#D3D3D3</SolidColorBrush>
    </Application.Resources>
</Application>
