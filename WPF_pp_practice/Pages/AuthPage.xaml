<Page
    x:Class="WPF_pp_practice.Pages.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPF_pp_practice.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="AuthPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="200">
        <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Center"
            Text="Логин" />
        <TextBox Name="LoginTextBox" Grid.Row="1" />
        <TextBlock
            Grid.Row="2"
            HorizontalAlignment="Center"
            Text="Пароль" />
        <PasswordBox Name="PasswordPasswordBox" Grid.Row="3" />

        <Button
            x:Name="AuthButton"
            Grid.Row="4"
            Margin="10"
            Click="AuthButton_Click"
            Content="Войти" />
        <Button
            x:Name="AuthAsGuestButton"
            Grid.Row="5"
            Margin="10"
            Click="AuthAsGuestButton_Click"
            Content="Войти как гость" />
    </StackPanel>
</Page>
