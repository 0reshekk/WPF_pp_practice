<Page
    x:Class="WPF_pp_practice.Pages.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPF_pp_practice.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="AuthPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <TextBox
            Name="LogTextBox"
            Width="120"
            Margin="0,174,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            TextWrapping="Wrap" />
        <TextBox
            Name="PassTextBox"
            Width="120"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            TextWrapping="Wrap" />
        <TextBlock
            Margin="371,199,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Text="Пароль"
            TextWrapping="Wrap" />
        <TextBlock
            Margin="371,155,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Text="Логин" />
        <Button
            Margin="0,248,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Click="Button_Click"
            Content="Войти в систему" />
        <Button
            Margin="0,313,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Content="Просмотреть продукцию" />
    </Grid>
</Page>
