<Page
    x:Class="WPF_pp_practice.Pages.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPF_pp_practice.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="AuthPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Center"
            Text="Логин" />
        <TextBox Name="LogTextBox" Grid.Row="1" />
        <TextBlock
            Grid.Row="2"
            HorizontalAlignment="Center"
            Text="Пароль" />
        <TextBox Name="PassTextBox" Grid.Row="3" />

        <Button
            Grid.Row="4"
            Click="Button_Click"
            Content="Войти в систему" />
        <Button
            Grid.Row="5"
            Click="Button_Click_1"
            Content="Просмотреть продукцию" />
    </StackPanel>

