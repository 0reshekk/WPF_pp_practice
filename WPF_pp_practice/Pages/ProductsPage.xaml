<Page
    x:Class="WPF_pp_practice.Pages.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPF_pp_practice.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ProductsPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <!--  Фильтры  -->

        <!--  Используем как header, не более, просто чтобы сверстать  -->
        <Grid>
            <StackPanel x:Name="FiltersStackPanel" Orientation="Horizontal">
                <TextBox
                    x:Name="SearchTextBox"
                    Width="250"
                    Margin="5"
                    TextChanged="Filter" />
                <ComboBox
                    x:Name="SortComboBox"
                    Width="130"
                    Margin="5"
                    SelectedIndex="0"
                    SelectionChanged="Filter" />
                <ComboBox
                    x:Name="TypeComboBox"
                    Width="130"
                    Margin="5"
                    DisplayMemberPath="Name"
                    SelectedIndex="0"
                    SelectionChanged="Filter" />
            </StackPanel>
            <Button
                x:Name="MaterialsButton"
                Width="130"
                Margin="5"
                HorizontalAlignment="Right"
                Click="MaterialsButton_Click">
                Материалы
            </Button>
        </Grid>

        <!--  Список  -->
        <ListView x:Name="ProductsListView" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Padding="15"
                        Background="Transparent"
                        BorderBrush="Black"
                        BorderThickness="1">
                        <Grid Height="80">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Grid.Column="0"
                                Margin="10"
                                Source="{Binding PhotoPath}" />

                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <TextBlock FontSize="18">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} | {1}">
                                            <Binding Path="ProductTypes.Name" />
                                            <Binding Path="Name" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="{Binding Article}" />
                                <TextBlock>
                                    <TextBlock.Text>
                                        <Binding Path="StringMaterials" StringFormat="{}Материалы: {0}" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Grid.Column="2">
                                <TextBlock.Text>
                                    <Binding Path="MinPrice" StringFormat="{}{0} руб." />
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding MinPriceMoreThan10k}" Value="True">
                            <Setter Property="Background" Value="#BB5FCA" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!--  Действия с продуктами  -->
        <StackPanel
            x:Name="ManagmentStackPanel"
            Grid.Row="2"
            Orientation="Horizontal">
            <Button
                x:Name="AddButton"
                Width="150"
                Margin="5"
                Click="AddButton_Click">
                Добавить
            </Button>
            <Button
                x:Name="EditButton"
                Width="150"
                Margin="5"
                Click="EditButton_Click">
                Изменить выбранное
            </Button>
            <Button
                x:Name="DeleteButton"
                Width="150"
                Margin="5"
                Click="DeleteButton_Click">
                Удалить выбранное
            </Button>
        </StackPanel>
    </Grid>
</Page>
