<Page
    x:Class="WPF_pp_practice.Pages.MaterialsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPF_pp_practice.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MaterialsPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <!--  Кнопка перехода к продуктам  -->
        <Button
            x:Name="ProductsButton"
            Width="130"
            Margin="5"
            HorizontalAlignment="Right"
            Click="ProductsButton_Click">
            Продукты
        </Button>

        <!--  Список  -->
        <DataGrid
            x:Name="MaterialsDataGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Name}" Header="Наименование" />
                <DataGridTextColumn Binding="{Binding MinQBox}" Header="Мин. в упакове" />
                <DataGridTextColumn Binding="{Binding Edinici.Name}" Header="Единица" />
                <DataGridTextColumn Binding="{Binding QSclad}" Header="Количество на складе" />
                <DataGridTextColumn Binding="{Binding MinVozm}" Header="Мин. возможное" />
                <DataGridTextColumn Binding="{Binding Price}" Header="Цена" />
            </DataGrid.Columns>
        </DataGrid>


        <!--  Действия с материалами  -->
        <StackPanel
            x:Name="ManagmentStackPanel"
            Grid.Row="2"
            Orientation="Horizontal">
            <Button
                x:Name="AddButton"
                Width="150"
                Margin="5"
                Click="AddButton_Click">
                Добавить
            </Button>
            <Button
                x:Name="EditButton"
                Width="150"
                Margin="5"
                Click="EditButton_Click">
                Изменить выбранное
            </Button>
            <Button
                x:Name="DeleteButton"
                Width="150"
                Margin="5"
                Click="DeleteButton_Click">
                Удалить выбранное
            </Button>
        </StackPanel>
    </Grid>
</Page>
